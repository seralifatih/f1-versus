# Supabase
# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Private (server/scripts only - NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Site
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AdSense
# Your AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-publisher-id-here

# AI Summary (Groq)
# Get a key at console.groq.com - leave blank to use template fallback summaries
GROQ_API_KEY=your-groq-api-key

# Vote security
# Change this to a long random string in production
VOTE_IP_HASH_SECRET=change-this-to-a-random-secret-in-production

# Cloudflare deployment
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare Web Analytics
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your-analytics-token-here
