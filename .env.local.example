# Cloudflare D1
# D1 is accessed via the DB binding in wrangler.toml — no URL or API key needed at runtime.
# For local development, run: wrangler d1 execute f1-versus-db --local --file=db/schema.sql
# The scripts (sync-data.ts, compute-comparisons.ts) use better-sqlite3 against the local
# Wrangler D1 state at .wrangler/state/v3/d1/*.sqlite

# Site
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AdSense
# Your AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-publisher-id-here

# AI Summary (Groq)
# Get a key at console.groq.com - leave blank to use template fallback summaries
GROQ_API_KEY=your-groq-api-key

# Vote security
# Change this to a long random string in production
# In production, set via: wrangler secret put VOTE_IP_HASH_SECRET
VOTE_IP_HASH_SECRET=change-this-to-a-random-secret-in-production

# Cloudflare deployment
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Cloudflare Web Analytics
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your-analytics-token-here
